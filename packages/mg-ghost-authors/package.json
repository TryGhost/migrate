{
  "name": "@tryghost/mg-ghost-authors",
  "version": "0.0.5",
  "description": "Fetch existing Ghost users and merge with migrated authors",
  "repository": "https://github.com/TryGhost/migrate/tree/main/packages/mg-ghost-authors",
  "author": "Ghost Foundation",
  "license": "MIT",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./build/index.js"
    }
  },
  "files": [
    "build"
  ],
  "scripts": {
    "dev": "echo \"Implement me!\"",
    "build:watch": "tsc --watch --preserveWatchOutput --sourceMap",
    "build": "rm -rf build && rm -rf tsconfig.tsbuildinfo && tsc --build --sourceMap",
    "prepare": "yarn build",
    "lint": "eslint src/ --ext .ts --cache",
    "test": "rm -rf build && yarn build --force && c8 --src src --all --reporter text --reporter cobertura node --test 'build/test/**/*.test.js'",
    "posttest": "yarn lint"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "c8": "11.0.0",
    "eslint": "8.57.1",
    "eslint-plugin-ghost": "3.5.0",
    "typescript": "6.0.2"
  },
  "dependencies": {
    "@tryghost/admin-api": "1.14.6",
    "@tryghost/errors": "3.0.3"
  }
}
