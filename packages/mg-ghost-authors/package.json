{
  "name": "@tryghost/mg-ghost-authors",
  "version": "0.7.0",
  "description": "Fetch existing Ghost users and merge with migrated authors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TryGhost/migrate.git",
    "directory": "packages/mg-ghost-authors"
  },
  "author": "Ghost Foundation",
  "license": "MIT",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./build/index.js"
    }
  },
  "files": [
    "build"
  ],
  "scripts": {
    "dev": "echo \"Implement me!\"",
    "build:watch": "tsc --watch --preserveWatchOutput --sourceMap",
    "build": "tsc --build --sourceMap",
    "lint": "eslint src/ --ext .ts --cache",
    "test": "c8 --src src --all --reporter text --reporter cobertura node --test 'build/test/**/*.test.js'",
    "test:local": "pnpm build && pnpm test",
    "posttest": "pnpm lint"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "c8": "11.0.0",
    "eslint": "8.57.1",
    "eslint-plugin-ghost": "3.5.0",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@tryghost/admin-api": "1.14.6",
    "@tryghost/errors": "3.0.3"
  }
}
