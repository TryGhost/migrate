{
  "name": "@tryghost/mg-queue",
  "version": "0.6.2",
  "repository": "https://github.com/TryGhost/migrate/tree/main/packages/mg-queue",
  "author": "Ghost Foundation",
  "license": "MIT",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "default": "./build/index.js"
    }
  },
  "scripts": {
    "build:watch": "tsc --watch --preserveWatchOutput --sourceMap",
    "build": "rm -rf build && rm -rf tsconfig.tsbuildinfo && tsc --build --sourceMap",
    "test": "c8 --src src --all --exclude '**/Renderer.ts' --exclude '**/test/**' --check-coverage --100 --reporter text --reporter cobertura node --test 'build/test/*.test.js'",
    "test:local": "pnpm build && pnpm test"
  },
  "files": [
    "build"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@tryghost/mg-context": "workspace:*",
    "@types/node": "catalog:",
    "c8": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "chalk": "catalog:",
    "log-update": "catalog:"
  }
}
