{
  "name": "@tryghost/mg-clean-html",
  "version": "0.6.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TryGhost/migrate.git",
    "directory": "packages/mg-clean-html"
  },
  "author": "Ghost Foundation",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./build/index.js"
    }
  },
  "files": [
    "build"
  ],
  "scripts": {
    "dev": "echo \"Implement me!\"",
    "build": "rm -rf build && rm -rf tsconfig.tsbuildinfo && tsc --build --sourceMap",
    "build:watch": "tsc --watch --preserveWatchOutput --sourceMap",
    "test": "rm -rf build && pnpm build --force && c8 --src src --all --check-coverage --100 --reporter text --reporter cobertura node --test 'build/test/**/*.test.js'",
    "posttest": "pnpm lint",
    "lint": "eslint src/ --ext .ts --cache"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "c8": "11.0.0",
    "eslint": "8.57.1",
    "eslint-plugin-ghost": "3.5.0",
    "typescript": "6.0.2"
  },
  "dependencies": {
    "@tryghost/mg-utils": "workspace:*",
    "escape-string-regexp": "5.0.0",
    "style-to-object": "1.0.14"
  }
}
