{
  "name": "@tryghost/mg-clean-html",
  "version": "0.12.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TryGhost/migrate.git",
    "directory": "packages/mg-clean-html"
  },
  "author": "Ghost Foundation",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "default": "./build/index.js"
    }
  },
  "files": [
    "build"
  ],
  "scripts": {
    "dev": "echo \"Implement me!\"",
    "build": "tsc --build --sourceMap",
    "build:watch": "tsc --watch --preserveWatchOutput --sourceMap",
    "test": "c8 --src src --all --check-coverage --100 --reporter text --reporter cobertura node --test 'build/test/**/*.test.js'",
    "test:local": "pnpm build && pnpm test",
    "posttest": "pnpm lint",
    "lint": "eslint src/ --ext .ts --cache"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "c8": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-ghost": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@tryghost/mg-utils": "workspace:*",
    "escape-string-regexp": "catalog:",
    "style-to-object": "1.0.14"
  }
}
