{
  "name": "@tryghost/mg-beehiiv-api",
  "version": "0.6.0",
  "repository": "https://github.com/TryGhost/migrate/tree/main/packages/mg-beehiiv-api",
  "author": "Ghost Foundation",
  "license": "MIT",
  "type": "module",
  "main": "build/index.js",
  "types": "build/types.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "default": "./build/index.js"
    }
  },
  "scripts": {
    "dev": "echo \"Implement me!\"",
    "build:watch": "tsc --watch --preserveWatchOutput --sourceMap",
    "build": "tsc --build --sourceMap",
    "lint": "eslint src/ --ext .ts --cache",
    "test:local": "pnpm build && pnpm test",
    "posttest": "pnpm lint",
    "test": "c8 --src src --all --check-coverage --100 --reporter text --reporter cobertura node --test build/test/*.test.js"
  },
  "files": [
    "build"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "c8": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@tryghost/errors": "catalog:",
    "@tryghost/mg-utils": "workspace:*",
    "@tryghost/string": "0.3.5",
    "simple-dom": "catalog:"
  }
}
