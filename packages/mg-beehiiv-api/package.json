  "type": "module",
  "main": "build/index.js",
  "types": "build/types.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./build/index.js"
    }
  },
  "scripts": {
    "dev": "echo \"Implement me!\"",
    "build:watch": "tsc --watch --preserveWatchOutput --sourceMap",
    "build": "rm -rf build && rm -rf tsconfig.tsbuildinfo && tsc --build --sourceMap",
    "lint": "eslint src/ --ext .ts --cache",
    "posttest": "pnpm lint",
    "test": "rm -rf build && pnpm build --force && c8 --src src --all --check-coverage --100 --reporter text --reporter cobertura node --test build/test/*.test.js"
  },
  "files": [
    "build"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/lodash": "4.17.24",
    "@types/node": "24.12.2",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "c8": "10.1.3",
    "dotenv": "17.4.1",
    "eslint": "8.57.1",
    "typescript": "6.0.2"
  },
  "dependencies": {
    "@tryghost/debug": "0.1.35",
    "@tryghost/errors": "1.3.8",
    "@tryghost/kg-default-cards": "10.2.5",
    "@tryghost/mg-fs-utils": "workspace:*",
    "@tryghost/mg-utils": "workspace:*",
    "@tryghost/string": "0.2.21",
    "lodash": "4.18.1",
    "sanitize-html": "2.17.0",
    "simple-dom": "1.4.0"
  }
