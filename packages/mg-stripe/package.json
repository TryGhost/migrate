{
  "name": "@tryghost/mg-stripe",
  "version": "0.12.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TryGhost/migrate.git",
    "directory": "packages/mg-stripe"
  },
  "author": "Ghost Foundation",
  "license": "MIT",
  "type": "module",
  "main": "build/index.js",
  "types": "build/types.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "default": "./build/index.js"
    }
  },
  "scripts": {
    "dev": "./cli.js stripe",
    "build:watch": "tsc --watch --preserveWatchOutput --sourceMap",
    "build": "rm -rf build && rm -rf tsconfig.tsbuildinfo && tsc --build --sourceMap",
    "lint": "eslint src/ --ext .ts --cache",
    "test:e2e": "pnpm build && node --test --test-concurrency=1 'build/test/e2e/**/*.test.js'",
    "test": "pnpm build && c8 --check-coverage --lines 90 --functions 80 --branches 80 --statements 90 node --test 'build/test/unit/**/*.test.js'",
    "posttest": "pnpm lint"
  },
  "files": [
    "build"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/sinon": "21.0.1",
    "@typescript-eslint/parser": "catalog:",
    "c8": "catalog:",
    "dotenv": "catalog:",
    "eslint": "catalog:",
    "sinon": "22.0.0",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@inquirer/input": "5.1.2",
    "@inquirer/prompts": "8.5.2",
    "@inquirer/select": "5.2.1",
    "@tryghost/pretty-cli": "catalog:",
    "chalk": "catalog:",
    "ora": "9.4.0",
    "stripe": "22.2.2"
  }
}
