{
  "name": "@tryghost/mg-stripe",
  "version": "0.6.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TryGhost/migrate.git",
    "directory": "packages/mg-stripe"
  },
  "author": "Ghost Foundation",
  "license": "MIT",
  "type": "module",
  "main": "build/index.js",
  "types": "build/types.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./build/index.js"
    }
  },
  "scripts": {
    "dev": "./cli.js stripe",
    "build:watch": "tsc --watch --preserveWatchOutput --sourceMap",
    "build": "rm -rf build && rm -rf tsconfig.tsbuildinfo && tsc --build --sourceMap",
    "lint": "eslint src/ --ext .ts --cache",
    "test:e2e": "pnpm build && node --test --test-concurrency=1 'build/test/e2e/**/*.test.js'",
    "test": "pnpm build && c8 --check-coverage --lines 90 --functions 80 --branches 80 --statements 90 node --test 'build/test/unit/**/*.test.js'",
    "posttest": "pnpm lint"
  },
  "files": [
    "build"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/inquirer": "9.0.9",
    "@types/node": "24.12.2",
    "@types/sinon": "21.0.1",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "c8": "11.0.0",
    "dotenv": "17.4.1",
    "eslint": "8.57.1",
    "sinon": "21.0.3",
    "typescript": "6.0.2"
  },
  "dependencies": {
    "@inquirer/input": "5.0.11",
    "@inquirer/prompts": "8.3.2",
    "@inquirer/select": "5.1.3",
    "@tryghost/debug": "2.0.3",
    "@tryghost/errors": "3.0.3",
    "@tryghost/pretty-cli": "3.0.3",
    "chalk": "5.6.2",
    "child_process": "1.0.2",
    "inquirer": "13.3.2",
    "ora": "9.3.0",
    "stripe": "22.0.0",
    "sywac": "1.3.0",
    "util": "0.12.5"
  }
}
