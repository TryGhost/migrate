{
  "private": true,
  "version": "0.0.0",
  "repository": "https://github.com/TryGhost/migrate",
  "author": "Ghost Foundation",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=22.21.1"
  },
  "eslintIgnore": [
    "**/node_modules/**"
  ],
  "scripts": {
    "dev": "NODE_ENV=development NODE_OPTIONS='--import tsx --conditions=source' ./packages/migrate/bin/cli.js",
    "dev:lessmemory": "NODE_OPTIONS=\"--max-old-space-size=2024 --import tsx --conditions=source\" NODE_ENV=development ./packages/migrate/bin/cli.js",
    "dev:morememory": "NODE_OPTIONS=\"--max-old-space-size=8192 --import tsx --conditions=source\" NODE_ENV=development ./packages/migrate/bin/cli.js",
    "dev:debug": "DEBUG_COLORS=true DEBUG=@tryghost*,migrate:* NODE_ENV=development NODE_OPTIONS='--import tsx --conditions=source' ./packages/migrate/bin/cli.js",
    "migrate": "migrate",
    "presetup": "pnpm install",
    "setup": "pnpm install",
    "test:only": "nx run-many -t test --parallel=10 --outputStyle=dynamic-legacy",
    "test": "nx run-many -t test lint --parallel=10 --outputStyle=dynamic-legacy",
    "test:ci": "nx run-many -t test lint --outputStyle=dynamic",
    "lint": "nx run-many -t lint --parallel=10 --outputStyle=dynamic-legacy",
    "build": "nx run-many -t build --parallel=10 --outputStyle=dynamic-legacy",
    "build:watch": "nx run-many -t build:watch --parallel=10 --outputStyle=dynamic-legacy",
    "ship": "pnpm test && nx release version --git-push --git-remote ${GHOST_UPSTREAM:-origin}",
    "ship:first-release": "pnpm ship --first-release",
    "update": "git pull origin main && pnpm install",
    "knip": "knip"
  },
  "devDependencies": {
    "@nx/js": "22.7.1",
    "@types/node": "24.12.2",
    "eslint": "8.57.1",
    "eslint-plugin-ghost": "3.5.0",
    "knip": "6.11.0",
    "nx": "22.7.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "nx",
      "sharp"
    ]
  }
}
